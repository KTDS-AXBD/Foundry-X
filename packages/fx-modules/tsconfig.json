{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esmoduleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@foundry-x/shared": ["../shared/src/index.ts"],
      "@foundry-x/shared-contracts": ["../shared-contracts/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../shared" },
    { "path": "../shared-contracts" }
  ]
}
