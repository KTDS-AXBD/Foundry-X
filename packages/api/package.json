{
  "name": "@foundry-x/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:workers": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate:sqlite --schema=src/db/schema.ts --out=src/db/migrations",
    "db:migrate:local": "wrangler d1 migrations apply foundry-x-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply foundry-x-db --remote",
    "db:seed:local": "wrangler d1 execute foundry-x-db --local --file=src/db/seed.sql",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/eslint-rules/ --max-warnings 0",
    "lint:msa-new": "bash ../../scripts/lint-new-files.sh"
  },
  "dependencies": {
    "@foundry-x/harness-kit": "workspace:*",
    "@foundry-x/shared": "workspace:*",
    "@hono/swagger-ui": "^0.4.0",
    "@hono/zod-openapi": "^0.9.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.0.0",
    "jszip": "^3.10.1",
    "nanoid": "^5.0.0",
    "pptxgenjs": "^4.0.1",
    "toucan-js": "^4.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.78.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "typescript-eslint": "^8.57.0"
  }
}
