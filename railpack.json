{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["pnpm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm --filter @foundry-x/shared build",
        "pnpm --filter @foundry-x/prototype-builder build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node prototype-builder/dist/index.js"
  }
}
