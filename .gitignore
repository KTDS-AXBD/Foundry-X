# bkit runtime state
.bkit/

# O-G-D workspace (라운드 산출물 임시 저장)
_workspace/

# Team config (개인정보 포함)
tools/team-config.json

node_modules/
dist/
.foundry-x/
.team-tmp/
*.tsbuildinfo
.turbo/
.next/

# tsc build artifacts (source is .ts)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map

# secrets
.env
.env.*
!.env.example
.dev.vars
.playwright-mcp/

# Cloudflare build artifacts
.wrangler/
.vercel/

# Next.js export output
out/
.gstack/

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Sprint worktree context (should only exist in worktrees, not master)
.sprint-context

# Tool caches / temp directories
.firecrawl/
_workspace-prev/

# Binary reference docs (PDF, DOCX, HTML — 참고자료는 Git 외부 관리)
docs/specs/**/*.pdf
docs/specs/**/*.docx
docs/specs/**/*.html

# TinaCMS generated
packages/web/tina/__generated__
